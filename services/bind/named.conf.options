options {
        directory "/var/cache/bind";

        listen-on { 127.0.0.1; <SERVER_IP>; <MGMT_IP>; };
        listen-on-v6 { none; };

        recursion yes;
        allow-recursion { localhost; <LAN_CIDR>; };
        allow-query { localhost; <LAN_CIDR>; };
        allow-transfer { none; };

        forwarders { <GATEWAY_IP>; };
        dnssec-validation auto;
};
